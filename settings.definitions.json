[
  {
    "title": "Appearance",
    "settings": {
      "theme": {
        "type": "string",
        "default": "dark",
        "label": "Theme",
        "description": "Color scheme of the panel",
        "options": [
          { "value": "dark", "label": "Dark" },
          { "value": "light", "label": "Light" }
        ]
      },
      "accentColor": {
        "type": "string",
        "default": "#40C4FF",
        "label": "Accent Color",
        "description": "Color used for gauge arcs and highlighted clock text"
      },
      "alignment": {
        "type": "string",
        "default": "left",
        "label": "Alignment",
        "description": "Horizontal alignment of the panel content",
        "options": [
          { "value": "left", "label": "Left" },
          { "value": "right", "label": "Right" }
        ]
      }
    }
  },
  {
    "title": "Weather",
    "settings": {
      "showWeather": {
        "type": "boolean",
        "default": false,
        "label": "Show Weather",
        "description": "Display current weather conditions"
      },
      "weatherCity": {
        "type": "string",
        "default": "",
        "label": "City",
        "description": "City name used to fetch weather data",
        "visibleWhen": { "key": "showWeather", "value": true }
      },
      "temperatureUnit": {
        "type": "string",
        "default": "celsius",
        "label": "Temperature Unit",
        "description": "Unit used to display temperatures",
        "visibleWhen": { "key": "showWeather", "value": true },
        "options": [
          { "value": "celsius", "label": "Celsius (°C)" },
          { "value": "fahrenheit", "label": "Fahrenheit (°F)" }
        ]
      }
    }
  },
  {
    "title": "Gauges",
    "settings": {
      "showBattery": {
        "type": "boolean",
        "default": true,
        "label": "Show Battery",
        "description": "Display the battery gauge (only visible if a battery is detected)"
      }
    }
  }
